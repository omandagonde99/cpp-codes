#include<iostream>
using namespace std;

bool search(int arr[], int n, int key ){
    for(int i=0; i<n; i++){
        if(arr[i]==key){
            return 1;

        }
    }
    return 0;
}

int main(){
    int n;
    cout<<"enter the size of array :";
    cin>>n;

    int arr[100];
    cout<<"enter the number in array :";
    for(int i=0; i<n; i++){
        cin>>arr[i];
    }

    int k;
    cout<<"enter the key :";
    cin>>k;

    bool found =search(arr,n,k);

    if(found){
        cout<<"the key is present ";
    }else{
        cout<<"the key is not present ";

    }

    return 0;

}
